POSTGRES_USER=your_username
POSTGRES_PASSWORD=your_password
POSTGRES_DB=db_name
DATABASE_URL=db_url

REDIS_URL=redis_url

JWT_SECRET=your_secret_key
JWT_EXPIRES_IN=n_days

# Registration restriction (for private/internal deployments)
# Set REGISTRATION_ENABLED=false to block all new sign-ups entirely.
# Set ALLOWED_EMAIL_USERNAMES to a comma-separated list of email usernames (the part before @).
# Example: ALLOWED_EMAIL_USERNAMES=john,jane,bob  allows john@gmail.com, jane@gmail.com, etc.
# Leave both unset to allow open registration (default for local dev).
REGISTRATION_ENABLED=true
ALLOWED_EMAIL_USERNAMES=

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-google-app-password
SMTP_FROM=DataPulse <your@gmail.com>

PORT=port_number

# Shopify Worker
PLAYWRIGHT_HEADLESS=true
SHOPIFY_DEFAULT_TIMEOUT=30000

# For ebay
EBAY_ENVIRONMENT=production
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_MARKETPLACE_ID=EBAY_GB
EBAY_SEARCH_LIMIT=200
EBAY_SEARCH_MAX_TOTAL=10000

#  For google shopping
SERPAPI_API_KEY=
GOOGLE_SHOPPING_SEARCH_LIMIT=400
GOOGLE_SHOPPING_PAGE_SIZE=40
GOOGLE_SHOPPING_MAX_PAGES=10
GOOGLE_SHOPPING_DEFAULT_COUNTRY=uk
GOOGLE_SHOPPING_DEFAULT_LANGUAGE=en

AMAZON_BASE_URL=https://www.amazon.co.uk
AMAZON_RESULT_LIMIT=20
# Without a proxy, success depends on a low request rate.
# Keep concurrency at 1, MAX_PAGES modest, and the job gap generous.
AMAZON_MAX_PAGES=2
AMAZON_WORKER_CONCURRENCY=1
AMAZON_HEADLESS=true

# Persistent browser profile dir (seeds session cookies across jobs).
AMAZON_USER_DATA_DIR=./.amazon-profile
# Visit homepage + accept cookies before searching.
AMAZON_WARMUP=true
# Minimum delay (ms) between Amazon jobs on one worker.
AMAZON_MIN_JOB_GAP_MS=30000

# Optional proxy values. Leave empty for local test.
AMAZON_PROXY_SERVER=
AMAZON_PROXY_USERNAME=
AMAZON_PROXY_PASSWORD=